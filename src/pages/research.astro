---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Pull submissions and publications from their content collections and sort
// by the `order` field. To add a new item, drop a .md file into
// src/content/submissions/ or src/content/publications/ — see the existing
// example files for the format.
const submissions = (await getCollection('submissions')).sort(
  (a, b) => a.data.order - b.data.order
);
const publications = (await getCollection('publications')).sort(
  (a, b) => a.data.order - b.data.order
);

// [PLACEHOLDER] Replace with 3–5 real research areas, or delete the section.
const researchAreas = [
  'AI and educational equity',
  'Algorithmic accountability in public services',
  'AI governance in the Hong Kong / Greater Bay Area context',
];
---

<BaseLayout
  title="Research & Policy"
  description="Research on the social, economic, and ethical dimensions of AI — put to work through formal submissions to government consultations and public bodies."
>
  <section class="section-tight">
    <div class="container prose">
      <p class="eyebrow">Research & Policy</p>
      <h1>Research &amp; Policy</h1>
      <p class="lead">
        We produce research on the social, economic, and ethical dimensions of
        artificial intelligence, and we put that research to work — through
        formal submissions to government consultations and recommendations to
        public bodies.
      </p>
    </div>
  </section>

  <!-- Government & policy submissions -->
  <section class="section-tight">
    <div class="container">
      <div class="prose">
        <h2>Government &amp; policy submissions</h2>
      </div>
      <ol class="entry-list">
        {
          submissions.map((item) => (
            <li class="entry">
              <h3>{item.data.title}</h3>
              <p class="entry-meta">
                Submitted to {item.data.submittedTo}, {item.data.date}.
              </p>
              <p class="entry-summary">{item.data.summary}</p>
              {item.data.pdf && (
                <a class="entry-link" href={item.data.pdf}>
                  Read the submission (PDF) →
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Publications & reports -->
  <section class="section-tight">
    <div class="container">
      <div class="prose">
        <h2>Publications &amp; reports</h2>
      </div>
      <ol class="entry-list">
        {
          publications.map((item) => (
            <li class="entry">
              <h3>{item.data.title}</h3>
              <p class="entry-meta">
                {item.data.date}
                {item.data.detail && <> · {item.data.detail}</>}
              </p>
              <p class="entry-summary">{item.data.summary}</p>
              {item.data.pdf && (
                <a class="entry-link" href={item.data.pdf}>
                  Download PDF →
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Research areas -->
  <section class="section-tight areas">
    <div class="container prose">
      <h2>Research areas</h2>
      <ul>
        {researchAreas.map((area) => <li>{area}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .entry-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    max-width: var(--measure);
  }

  .entry {
    padding-block: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .entry h3 {
    margin-bottom: 0.4rem;
  }

  .entry-meta {
    color: var(--color-text-soft);
    font-size: 0.95rem;
    margin-bottom: 0.6rem;
  }

  .entry-summary {
    margin-bottom: 0.75rem;
  }

  .entry-link {
    font-weight: 500;
    font-size: 0.97rem;
  }

  .areas {
    border-top: 1px solid var(--color-border);
  }
</style>
