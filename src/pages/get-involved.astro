---
import BaseLayout from '../layouts/BaseLayout.astro';

// Contact email is on file (dudequa3@gmail.com) but intentionally left blank
// for now. When you're ready to publish it, set `email` to that address — the
// "email us" links and the contact line will appear automatically. While it's
// empty, all contact routes through the form below. Social links omitted for now.
const email = '';

---

<BaseLayout
  title="Get Involved"
  description="Join, partner, or get in touch with AI For Good — a student-led think tank in Hong Kong."
>
  <section class="section-tight">
    <div class="container prose">
      <p class="eyebrow">Get Involved</p>
      <h1>Get Involved</h1>
    </div>
  </section>

  <!-- Three paths -->
  <section class="section-tight">
    <div class="container paths">
      <div class="path">
        <h2>Students</h2>
        <p>
          Want to do real research or teach? We look for people who care more
          about the work than the title.
          {email ? (
            <Fragment> <a href={`mailto:${email}`}>Email us</a> to apply.</Fragment>
          ) : (
            <Fragment> Use the <a href="#contact">form below</a> to apply.</Fragment>
          )}
        </p>
      </div>
      <div class="path">
        <h2>Schools &amp; Partners</h2>
        <p>
          If you run a school or program serving underserved students, we'd like
          to work with you.
          {email ? (
            <Fragment> <a href={`mailto:${email}`}>Get in touch.</a></Fragment>
          ) : (
            <Fragment> Reach us through the <a href="#contact">form below</a>.</Fragment>
          )}
        </p>
      </div>
      <div class="path">
        <h2>Everyone else</h2>
        <p>
          Press, collaboration, or just questions — get in touch using the form
          below.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact form (Netlify Forms — no backend needed) -->
  <section id="contact" class="section-tight contact">
    <div class="container">
      <div class="prose">
        <h2>Contact us</h2>
        <p class="contact-meta">
          {email && <>Email: <a href={`mailto:${email}`}>{email}</a><br /></>}
          Based in Hong Kong.
        </p>
      </div>

      <!--
        Netlify Forms: the `data-netlify` attribute and the hidden `form-name`
        input let Netlify detect and capture submissions automatically at
        deploy time — no server or backend required. The honeypot field
        (`bot-field`) filters out simple spam bots. Submissions appear in your
        Netlify dashboard under Forms.
      -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>

        <div class="field">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required />
        </div>

        <div class="field">
          <label for="organization">Organization <span class="optional">(optional)</span></label>
          <input id="organization" type="text" name="organization" />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Send message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .paths {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .path h2 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .path p {
    color: var(--color-text-soft);
  }

  .contact {
    border-top: 1px solid var(--color-border);
  }

  .contact-meta {
    color: var(--color-text-soft);
  }

  .contact-form {
    max-width: var(--measure);
    margin-top: 1.75rem;
  }

  .field {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .optional {
    color: var(--color-text-soft);
    font-weight: 400;
  }

  .field input,
  .field textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
    outline: 2px solid transparent;
  }

  .field textarea {
    resize: vertical;
  }

  /* Honeypot field — hidden from real users */
  .hidden-field {
    position: absolute;
    left: -9999px;
  }

  @media (max-width: 52rem) {
    .paths {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
