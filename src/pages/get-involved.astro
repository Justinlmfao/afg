---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';

// Contact email is on file (dudequa3@gmail.com) but intentionally left blank
// for now. When ready, set `email` to that address — the "email us" links and
// the contact line appear automatically. While empty, contact routes through
// the form. Social links omitted for now.
const email = '';

const paths = [
  {
    title: 'Students',
    icon: 'education',
    variant: 'cool',
    body:
      "Want to do real research or teach? We look for people who care more about the work than the title. Tell us what you'd want to work on.",
  },
  {
    title: 'Schools & Partners',
    icon: 'engagement',
    variant: 'warm',
    body:
      "If you run a school or program serving underserved students, we'd like to work with you. We bring the curriculum, the volunteers, and the equipment.",
  },
  {
    title: 'Everyone else',
    icon: 'research',
    variant: 'teal',
    body: 'Press, collaboration, or questions — get in touch.',
  },
];
---

<BaseLayout
  title="Get Involved"
  description="Join, partner, or get in touch with AI For Good — a student-led think tank in Hong Kong."
>
  <PageHero
    eyebrow="Get Involved"
    titlePre="Get"
    titleAccent="Involved"
    lead="Join the work, partner with us, or just say hello — we bring the curriculum, the volunteers, and the equipment."
  />

  <!-- Three paths -->
  <section class="section-tight">
    <div class="container paths">
      {
        paths.map((p, i) => (
          <div class={`path magnify variant-${p.variant}`} data-reveal style={`--reveal-delay:${i * 0.1}s`}>
            <span class="path-badge" aria-hidden="true">
              <Icon name={p.icon} />
            </span>
            <h2>{p.title}</h2>
            <p>{p.body}</p>
            <a class="path-link link-underline" href="#contact">
              {p.title === 'Students'
                ? 'Apply below'
                : p.title === 'Schools & Partners'
                  ? 'Partner with us'
                  : 'Say hello'}{' '}
              →
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Contact form (Netlify Forms — no backend needed) -->
  <section id="contact" class="section-tight contact tint-cool">
    <div class="container">
      <div class="prose">
        <h2 data-reveal>Contact us</h2>
        <p class="contact-meta" data-reveal>
          {email && <>Email: <a href={`mailto:${email}`}>{email}</a><br /></>}
          Based in Hong Kong.
        </p>
      </div>

      <!--
        Netlify Forms: the `data-netlify` attribute and the hidden `form-name`
        input let Netlify detect and capture submissions automatically at
        deploy time — no server required. The honeypot field (`bot-field`)
        filters simple spam bots. Submissions appear in your Netlify dashboard.
      -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
        data-reveal
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>

        <div class="field">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required />
        </div>

        <div class="field">
          <label for="organization">Organisation <span class="optional">(optional)</span></label>
          <input id="organization" type="text" name="organization" />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">
          Send message <span class="arrow">→</span>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .paths {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .path {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.9rem;
    box-shadow: var(--shadow-sm);
    border-top: 5px solid var(--pbar, var(--indigo));
  }

  .path-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 14px;
    color: #fff;
    background: var(--pbar, var(--grad-cool));
    margin-bottom: 1rem;
  }

  .path h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .path p {
    color: var(--color-text-soft);
    margin-bottom: 1rem;
  }

  .path-link {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .variant-cool {
    --pbar: linear-gradient(135deg, #4f46e5, #2563eb);
  }
  .variant-warm {
    --pbar: linear-gradient(135deg, #f97316, #ec4899);
  }
  .variant-teal {
    --pbar: linear-gradient(135deg, #0d9488, #059669);
  }

  .contact-meta {
    color: var(--color-text-soft);
  }

  .contact-form {
    max-width: var(--measure);
    margin-top: 1.75rem;
  }

  .field {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .optional {
    color: var(--color-text-soft);
    font-weight: 400;
  }

  .field input,
  .field textarea {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
    outline: none;
  }

  .field textarea {
    resize: vertical;
  }

  .hidden-field {
    position: absolute;
    left: -9999px;
  }

  @media (max-width: 52rem) {
    .paths {
      grid-template-columns: 1fr;
    }
  }
</style>
