---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout
  title="About"
  description="AI For Good exists to ensure artificial intelligence develops in a way that serves the public good — through rigorous research, direct policy engagement, and education."
>
  <section class="section-tight">
    <div class="container prose">
      <p class="eyebrow">About</p>
      <h1>About AI For Good</h1>
    </div>
  </section>

  <!-- Mission -->
  <section class="section-tight">
    <div class="container prose">
      <h2>Our mission</h2>
      <p>
        AI For Good exists to ensure that artificial intelligence develops in a
        way that serves the public good — especially for communities with the
        least power to shape it. We do this through rigorous research, direct
        policy engagement, and education that reaches the people technology
        usually overlooks.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="section-tight">
    <div class="container prose">
      <h2>Our story</h2>
      <p>
        AI For Good began as a student club at Victoria Shanghai Academy. Over
        <!-- [PLACEHOLDER] confirm exact number of years -->[THREE] years it
        grew into something larger: a student-led think tank producing original
        policy research, making formal submissions to government, and running AI
        literacy programs across Hong Kong.
      </p>
      <p>
        What stayed constant was a belief that students shouldn't wait for
        permission to do serious work. The questions raised by AI — about
        fairness, access, and accountability — will define our generation more
        than any other. We decided to start answering them now.
      </p>
    </div>
  </section>

  <!-- What makes us different -->
  <section>
    <div class="container">
      <div class="prose">
        <h2>What makes us different</h2>
      </div>
      <div class="cards-grid">
        <Card title="Evidence over opinion">
          Every position we take is grounded in research. We'd rather be careful
          and right than loud and wrong.
        </Card>
        <Card title="We do, not just discuss">
          A think tank that only talks is a debate club. We translate research
          into submissions, programs, and measurable outreach.
        </Card>
        <Card title="Access is the mission">
          Most conversations about AI happen among people who already have power
          and resources. We deliberately work with those who don't.
        </Card>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-tight values">
    <div class="container prose">
      <h2>Our values</h2>
      <ul>
        <li>
          <strong>Intellectual humility</strong> — we hold our views openly and
          revise them with evidence.
        </li>
        <li>
          <strong>Service before recognition</strong> — impact matters more than
          titles.
        </li>
        <li>
          <strong>Civil, evidence-based discourse</strong> — we make arguments,
          not noise.
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .values {
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 52rem) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
