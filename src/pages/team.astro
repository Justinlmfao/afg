---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Team members come from src/content/team/ (drafts excluded). The `group`
// field controls which section a person appears under; the order of groups
// below controls section order on the page.
const members = (await getCollection('team')).filter((m) => !m.data.draft);

const groupOrder = ['Leadership', 'Executive Team'];

const grouped = groupOrder
  .map((group) => ({
    group,
    people: members
      .filter((m) => m.data.group === group)
      .sort((a, b) => a.data.order - b.data.order),
  }))
  .filter((section) => section.people.length > 0);

// Colourful gradients cycled across avatars.
const gradients = [
  'linear-gradient(135deg,#4f46e5,#2563eb)',
  'linear-gradient(135deg,#f97316,#ec4899)',
  'linear-gradient(135deg,#0d9488,#059669)',
  'linear-gradient(135deg,#7c3aed,#4f46e5)',
  'linear-gradient(135deg,#f59e0b,#ef4444)',
];

const initials = (name: string) =>
  name
    .split(' ')
    .map((w) => w[0])
    .slice(0, 2)
    .join('');

let avatarIndex = 0;
---

<BaseLayout
  title="Our Team"
  description="AI For Good is run entirely by students, organised into research, partnerships, and education teams."
>
  <section class="section-tight team-hero">
    <div class="blob" style="background:#c4b5fd;width:18rem;height:18rem;top:-5rem;right:-3rem" data-parallax="0.6"></div>
    <div class="container prose">
      <p class="eyebrow" data-reveal>Our Team</p>
      <h1 data-reveal>Our <span class="gradient-text">Team</span></h1>
      <p class="lead" data-reveal style="--reveal-delay:0.1s">
        AI For Good is run entirely by students, organised into research,
        partnerships, and education teams.
      </p>
    </div>
  </section>

  {
    grouped.map((section) => (
      <section class="section-tight team-section">
        <div class="container">
          <p class="eyebrow" data-reveal>{section.group}</p>
          <ul class="people-grid">
            {section.people.map((person, i) => {
              const grad = gradients[avatarIndex++ % gradients.length];
              return (
                <li
                  class="person magnify"
                  data-reveal
                  style={`--reveal-delay:${i * 0.08}s`}
                >
                  <span class="avatar" style={`background:${grad}`} aria-hidden="true">
                    {initials(person.data.name)}
                  </span>
                  <p class="person-name">{person.data.name}</p>
                  <p class="person-role">{person.data.role}</p>
                  <p class="person-bio">{person.data.bio}</p>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    ))
  }
</BaseLayout>

<style>
  .team-hero {
    position: relative;
    overflow: hidden;
  }

  .people-grid {
    list-style: none;
    padding: 0;
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1.5rem;
  }

  .person {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .person-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
  }

  .person-role {
    color: var(--color-accent);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-block: 0.2rem 0.6rem;
  }

  .person-bio {
    color: var(--color-text-soft);
    font-size: 0.97rem;
  }
</style>
