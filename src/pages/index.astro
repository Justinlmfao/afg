---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsBand from '../components/StatsBand.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import ParticleField from '../components/ParticleField.astro';

// Hero headline, split into word tokens for a cinematic staggered reveal.
// Each token keeps its trailing space; `grad` marks the gradient word.
const headline = [
  'Technology ', 'and ', 'policy ', 'should ', 'serve ',
  { t: 'everyone. ', grad: true },
  'We ', 'do ', 'the ', 'work ', 'to ', 'make ', 'sure ', 'they ', 'do.',
];

// Policy areas scrolled in the marquee band (decorative breadth cue).
const topics = [
  'Taxation', 'AI governance', 'Education', 'Labour', 'Public health',
  'Human capital', 'Innovation', 'Algorithmic accountability',
  'The Greater Bay Area', 'The future of work',
];

// Featured work shown on the home page (links into /research).
const featured = [
  {
    title: "Submission to Hong Kong's First Five-Year Plan (2026–2030)",
    tag: 'In progress',
  },
  {
    title: 'Tax Relief and Household Resilience — Submission to the 2025–26 Budget',
    tag: 'Submission',
  },
  {
    title: 'The Spark Gap: AI Literacy and Educational Inequality in Hong Kong',
    tag: 'Report',
  },
];
---

<BaseLayout title="AI For Good">
  <!-- Hero: a dark cinematic opening — aurora light, glowing particle
       network, and a word-by-word headline reveal -->
  <section class="hero" data-dark-hero>
    <ParticleField color="139,148,255" />
    <div class="blob blob-1" style="background:#6366f1" data-parallax="0.5"></div>
    <div class="blob blob-2" style="background:#db2777" data-parallax="0.9"></div>
    <div class="blob blob-3" style="background:#14b8a6" data-parallax="0.3"></div>

    <div class="container hero-inner">
      <p class="eyebrow" data-reveal>Student-led · Hong Kong · since 2023</p>
      <h1 class="reveal-words">
        {
          headline.map((word, i) => {
            const text = typeof word === 'string' ? word : word.t;
            const grad = typeof word !== 'string' && word.grad;
            return (
              <span class="word">
                <span
                  class={grad ? 'word-inner gradient-text-bright hero-accent' : 'word-inner'}
                  style={`--wd:${(0.2 + i * 0.05).toFixed(2)}s`}
                >
                  {text}
                </span>
              </span>
            );
          })
        }
      </h1>
      <p class="lead hero-subhead" data-reveal style="--reveal-delay:0.85s">
        AI For Good is a student-led think tank in Hong Kong. We produce policy
        research, submit evidence-based recommendations to government, and teach
        children to use AI as a tool to close the gap that wealth would
        otherwise decide.
      </p>
      <div class="hero-actions" data-reveal style="--reveal-delay:1s">
        <a class="btn btn-primary" href="/research" data-magnetic>
          Read our research <span class="arrow">→</span>
        </a>
        <a class="btn btn-secondary btn-ghost" href="/get-involved" data-magnetic>
          Get involved <span class="arrow">→</span>
        </a>
      </div>
    </div>

    <div class="scroll-cue" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </div>
  </section>

  <!-- Stats band (animated count-up) -->
  <StatsBand />

  <!-- What we do -->
  <section class="tint-cool">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="section-idx" aria-hidden="true">01</span>
        <p class="eyebrow">What we do</p>
      </div>
      <div class="cards-grid">
        <Card title="Research & Policy" icon="research" variant="cool">
          We research how AI and economic policy shape society, and submit
          roughly twenty evidence-based recommendations a year to government —
          from the annual Budget to Hong Kong's First Five-Year Plan.
        </Card>
        <Card title="Education & Outreach" icon="education" variant="warm">
          We teach AI and economic literacy to underprivileged students across
          Hong Kong — 350 children and counting — by showing them how to use AI
          as a free, patient tutor, the kind their wealthier peers pay for.
        </Card>
        <Card title="Public Engagement" icon="engagement" variant="teal">
          We bring students, educators, and policymakers into the same room, on
          the conviction that the people who will live longest with these
          decisions should help shape them.
        </Card>
      </div>
    </div>
  </section>

  <!-- Topic marquee — the breadth of policy areas, quietly in motion -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...topics, ...topics].map((t) => <span class="marquee-item">{t}</span>)}
    </div>
  </div>

  <!-- Featured work -->
  <section>
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="section-idx" aria-hidden="true">02</span>
        <p class="eyebrow">Featured work</p>
      </div>
      <ul class="featured-list">
        {
          featured.map((item, i) => (
            <li class="featured-item magnify" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
              <a href="/research">
                <span class="featured-tag">{item.tag}</span>
                <span class="featured-title">{item.title}</span>
                <span class="featured-arrow" aria-hidden="true">
                  <Icon name="arrow" size={22} />
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Closing: a dark, cinematic sign-off that mirrors the opening -->
  <section class="closing">
    <div class="container closing-inner">
      <p class="closing-line" data-reveal>
        We're students. We think that's{' '}
        <span class="gradient-text-bright closing-accent">the point</span>.
      </p>
      <p class="closing-sub" data-reveal style="--reveal-delay:0.12s">
        The people who will inherit these decisions should have a hand in
        shaping them.
      </p>
      <div class="closing-actions" data-reveal style="--reveal-delay:0.24s">
        <a class="btn btn-primary" href="/get-involved" data-magnetic>
          Join us <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    color: #fff;
    padding-block: clamp(5rem, 13vw, 10rem);
    /* Aurora light over deep indigo — ends on the stats band's colour so the
       two sections read as one continuous cinematic opening. */
    background:
      radial-gradient(60rem 38rem at 85% -12%, rgba(99, 102, 241, 0.4), transparent 62%),
      radial-gradient(48rem 32rem at -10% 112%, rgba(219, 39, 119, 0.22), transparent 60%),
      radial-gradient(40rem 28rem at 68% 88%, rgba(20, 184, 166, 0.22), transparent 55%),
      linear-gradient(180deg, #0a0a20, #14143c 62%, #0f1030);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    max-width: 20ch;
    color: #fff;
    font-size: clamp(2.6rem, 6.5vw, 4.6rem);
    text-shadow: 0 2px 40px rgba(10, 10, 32, 0.6);
  }

  /* The gradient word gets an italic, editorial flourish */
  .hero :global(.hero-accent) {
    font-style: italic;
    padding-right: 0.06em;
  }

  .hero-subhead {
    max-width: 50ch;
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.78);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.5rem;
  }

  /* Ghost secondary button for the dark hero */
  .btn-ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.07);
  }

  .btn-ghost:hover {
    background: #fff;
    color: #1e1b4b;
    border-color: #fff;
  }

  /* Floating aurora blobs (screen-blended so they glow on the dark base) */
  .hero .blob {
    mix-blend-mode: screen;
    opacity: 0.55;
  }
  .blob-1 {
    width: 26rem;
    height: 26rem;
    top: -8rem;
    right: -6rem;
    animation: floatY 9s ease-in-out infinite;
  }
  .blob-2 {
    width: 20rem;
    height: 20rem;
    bottom: -8rem;
    left: -5rem;
    animation: floatX 11s ease-in-out infinite;
  }
  .blob-3 {
    width: 14rem;
    height: 14rem;
    top: 30%;
    right: 22%;
    opacity: 0.35;
    animation: floatY 7s ease-in-out infinite;
  }

  /* Bouncing scroll cue at the base of the hero */
  .scroll-cue {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.55);
    animation: cueBob 2.2s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes cueBob {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.55;
    }
    50% {
      transform: translateX(-50%) translateY(8px);
      opacity: 1;
    }
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* Featured work list */
  .featured-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .featured-item a {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.4rem 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-text);
  }

  .featured-tag {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--grad-cool);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    flex: 1;
  }

  .featured-arrow {
    color: var(--color-accent);
    transition: transform 0.2s ease;
  }

  .featured-item:hover .featured-arrow {
    transform: translateX(6px);
  }

  /* Dark cinematic closing that mirrors the hero */
  .closing {
    text-align: center;
    color: #fff;
    background:
      radial-gradient(50rem 30rem at 50% 120%, rgba(99, 102, 241, 0.35), transparent 60%),
      linear-gradient(180deg, #0b0b24, #14143c);
    overflow: hidden;
  }

  .closing-inner {
    position: relative;
    z-index: 1;
  }

  .closing-line {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    line-height: 1.25;
    max-width: 22ch;
    margin-inline: auto;
  }

  .closing :global(.closing-accent) {
    font-style: italic;
    padding-right: 0.06em;
  }

  .closing-sub {
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    max-width: 44ch;
    margin: 1.25rem auto 0;
  }

  .closing-actions {
    margin-top: 2.25rem;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 52rem) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
    .featured-item a {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }
</style>
