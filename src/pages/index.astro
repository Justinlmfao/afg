---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatsBand from '../components/StatsBand.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="AI For Good">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Technology and policy should serve everyone. We do the work to make sure they do.</h1>
      <p class="lead hero-subhead">
        AI For Good is a student-led think tank in Hong Kong. We produce policy
        research, submit evidence-based recommendations to government, and teach
        AI and economic literacy to communities too often left out of the
        conversation.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/research">Read our research →</a>
        <a class="btn btn-secondary" href="/get-involved">Get involved →</a>
      </div>
    </div>
  </section>

  <!-- Stats band -->
  <StatsBand />

  <!-- What we do -->
  <section>
    <div class="container">
      <p class="eyebrow">What we do</p>
      <div class="cards-grid">
        <Card title="Research & Policy">
          We research how AI and economic policy shape society, and submit
          roughly twenty evidence-based recommendations a year to government
          consultations and public bodies — from the annual Budget to Hong
          Kong's first five-year plan.
        </Card>
        <Card title="Education & Outreach">
          We teach AI and economic literacy to underprivileged students across
          Hong Kong — 350 children and counting — because understanding the
          forces shaping the economy shouldn't depend on where you're born.
        </Card>
        <Card title="Public Engagement">
          We bring students, educators, and policymakers into the same room, on
          the conviction that the people who will live longest with these
          decisions should help shape them.
        </Card>
      </div>
    </div>
  </section>

  <!-- Closing line -->
  <section class="closing">
    <div class="container prose">
      <p class="closing-line">We're students. We think that's the point.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }

  .hero h1 {
    max-width: 18ch;
  }

  .hero-subhead {
    max-width: 46ch;
    margin-top: 1.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.25rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .closing {
    border-top: 1px solid var(--color-border);
  }

  .closing-line {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    line-height: 1.4;
    color: var(--color-text);
  }

  @media (max-width: 52rem) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
