---
// A simple content card used for the "What we do" and "Values" sections.
// Pass a `title` and put the body text in the default slot.
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<article class="card">
  <h3>{title}</h3>
  <div class="card-body"><slot /></div>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    height: 100%;
  }

  .card h3 {
    margin-bottom: 0.6rem;
  }

  .card-body {
    color: var(--color-text-soft);
  }
</style>
