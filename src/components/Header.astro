---
// Site header + primary navigation.
// The mobile menu toggle is progressively enhanced with a tiny inline script;
// without JS the nav simply stays visible.
const links = [
  { href: '/about', label: 'About' },
  { href: '/research', label: 'Research' },
  { href: '/programs', label: 'Programs' },
  { href: '/team', label: 'Team' },
  { href: '/get-involved', label: 'Get Involved' },
];

// Highlight the current section.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="AI For Good — home">AI&nbsp;For&nbsp;Good</a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle navigation menu"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={path === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .primary-nav ul {
    list-style: none;
    display: flex;
    gap: 1.6rem;
    padding: 0;
    margin: 0;
  }

  .primary-nav a {
    color: var(--color-text-soft);
    text-decoration: none;
    font-size: 0.97rem;
    font-weight: 500;
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
  }

  .primary-nav a:hover {
    color: var(--color-text);
  }

  .primary-nav a[aria-current='page'] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  /* Mobile menu toggle — hidden on larger screens */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle-bar {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    border-radius: 2px;
  }

  @media (max-width: 46rem) {
    .nav-toggle {
      display: flex;
    }

    .primary-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .primary-nav.is-open {
      display: block;
    }

    .primary-nav ul {
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 1.5rem 1rem;
    }

    .primary-nav li {
      border-top: 1px solid var(--color-border);
    }

    .primary-nav a {
      display: block;
      padding: 0.8rem 0;
      border-bottom: none;
    }

    .primary-nav a[aria-current='page'] {
      border-bottom: none;
      color: var(--color-accent);
    }
  }
</style>

<script>
  // Progressive enhancement: toggle the mobile nav.
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
  });
</script>
