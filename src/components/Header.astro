---
// Site header + primary navigation. The brand uses an animated gradient; the
// bar gains a shadow once you scroll. Mobile menu is progressively enhanced.
const links = [
  { href: '/about', label: 'About' },
  { href: '/research', label: 'Research' },
  { href: '/programs', label: 'Programs' },
  { href: '/team', label: 'Team' },
  { href: '/get-involved', label: 'Get Involved' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="AI For Good — home">
      <span class="brand-dot" aria-hidden="true"></span>
      <span class="gradient-text">AI&nbsp;For&nbsp;Good</span>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle navigation menu"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-underline"
                aria-current={path === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: rgba(251, 249, 245, 0.8);
    backdrop-filter: blur(12px);
    z-index: 90;
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .site-header.scrolled {
    box-shadow: 0 6px 24px rgba(21, 19, 26, 0.08);
    border-bottom-color: var(--color-border);
  }

  /* While a dark hero is in view the header becomes dark glass */
  .site-header.on-dark,
  .site-header.on-dark.scrolled {
    background: rgba(10, 10, 32, 0.92);
    backdrop-filter: blur(12px);
    box-shadow: none;
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .site-header.on-dark .primary-nav a {
    color: rgba(255, 255, 255, 0.72);
  }

  .site-header.on-dark .primary-nav a:hover {
    color: #fff;
  }

  .site-header.on-dark .primary-nav a[aria-current='page'] {
    color: #c7d2fe;
  }

  .site-header.on-dark .nav-toggle-bar {
    background: #fff;
  }

  /* The opened mobile panel keeps its light background, so restore dark text */
  .site-header.on-dark .primary-nav.is-open a {
    color: var(--color-text-soft);
  }

  .site-header.on-dark .primary-nav.is-open a[aria-current='page'] {
    color: var(--color-accent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.25rem;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .brand-dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--grad-rainbow);
    background-size: 200% 200%;
    animation: gradientShift 5s ease infinite, pulseGlow 3s ease infinite;
  }

  .primary-nav ul {
    list-style: none;
    display: flex;
    gap: 1.7rem;
    padding: 0;
    margin: 0;
  }

  .primary-nav a {
    color: var(--color-text-soft);
    text-decoration: none;
    font-size: 0.97rem;
    font-weight: 600;
  }

  .primary-nav a:hover {
    color: var(--color-text);
  }

  .primary-nav a[aria-current='page'] {
    color: var(--color-accent);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-toggle-bar {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    border-radius: 2px;
  }

  @media (max-width: 46rem) {
    .nav-toggle {
      display: flex;
    }

    .primary-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .primary-nav.is-open {
      display: block;
    }

    .primary-nav ul {
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 1.5rem 1rem;
    }

    .primary-nav li {
      border-top: 1px solid var(--color-border);
    }

    .primary-nav a {
      display: block;
      padding: 0.85rem 0;
    }
  }
</style>

<script>
  // Mobile nav toggle
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
  });

  // Shadow on scroll
  const header = document.getElementById('site-header');
  const setShadow = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  window.addEventListener('scroll', setShadow, { passive: true });
  setShadow();
</script>
