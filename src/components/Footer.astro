---
// Site footer.
// Contact email is on file (dudequa3@gmail.com) but left blank for now. Set
// `email` to that address when ready and the contact line will appear.
// Social links omitted for now.
const year = new Date().getFullYear();
const email = '';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-brand">AI For Good</p>
      <p class="footer-tagline">
        A student-led think tank in Hong Kong working at the intersection of
        technology, economics, and policy.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <a href="/about">About</a>
      <a href="/research">Research</a>
      <a href="/programs">Programs</a>
      <a href="/team">Team</a>
      <a href="/get-involved">Get Involved</a>
    </nav>

    <div class="footer-contact">
      {email && <a href={`mailto:${email}`}>{email}</a>}
      <p class="footer-meta">Based in Hong Kong · &copy; {year} AI For Good</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: auto;
    padding-block: 3rem;
    font-size: 0.95rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }

  .footer-tagline {
    color: var(--color-text-soft);
    max-width: 28rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: var(--color-text-soft);
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  .footer-contact a {
    font-weight: 500;
  }

  .footer-meta {
    color: var(--color-text-soft);
    margin-top: 0.75rem;
    font-size: 0.85rem;
  }

  @media (max-width: 46rem) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
</style>
